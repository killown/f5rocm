{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Matrix Voice Studio",
  "version": "0.1.0",
  "identifier": "com.matrix.voice",
  "build": {
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Matrix Voice Studio",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Initializing",
        "width": 450,
        "height": 250,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: http://localhost:7860 ws://localhost:7860; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:7860; style-src 'self' 'unsafe-inline' http://localhost:7860; img-src 'self' data: http://localhost:7860; media-src 'self' http://localhost:7860; connect-src 'self' http://localhost:7860 ws://localhost:7860;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["curl", "wget"]
      }
    }
  }
}
